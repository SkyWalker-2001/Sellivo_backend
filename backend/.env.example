# Copy to .env for local development
NODE_ENV=development

# API
API_PORT=3000

# Postgres (matches infra/docker-compose.yml)
DATABASE_URL=postgresql://sellivo:sellivo@localhost:5432/sellivo?schema=public

# Redis (matches infra/docker-compose.yml)
REDIS_URL=redis://localhost:6379

# Auth (Phase 0 — placeholder; real secrets set per environment)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_CUSTOMER_SECRET=dev-customer-secret-change-me
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d
JWT_CUSTOMER_TTL=30d

# Storefront tenant pin — the org the customer storefront serves (one per deployment/domain).
STOREFRONT_ORG_ID=

# SMS OTP for customer phone login. Provider: textbelt | twilio | console
SMS_PROVIDER=textbelt
SMS_TEXTBELT_KEY=textbelt
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Google sign-in: comma-separated OAuth client IDs allowed as ID-token audience.
GOOGLE_CLIENT_IDS=

# Payments (Phase 3 — Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
